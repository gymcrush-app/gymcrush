{
  "expo": {
    "owner": "gymcrush-app",
    "name": "GymCrush",
    "slug": "gymcrush",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/GymCrush-Icon-Final.png",
    "scheme": "gymcrush",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/GymCrush-Load-Screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gymcrushdating.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GymCrush uses your location to find gyms and gym-goers near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GymCrush uses your location to find gyms and gym-goers near you.",
        "NSPhotoLibraryUsageDescription": "GymCrush needs access to your photos so you can show off your gym gains on your profile.",
        "NSCameraUsageDescription": "GymCrush uses your camera so you can snap fresh profile pics on the spot.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.gymcrush.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/notification.caf"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GymCrush uses your location to find gyms and gym-goers near you.",
          "locationAlwaysAndWhenInUsePermission": "GymCrush uses your location to find gyms and gym-goers near you."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "gym-crush",
          "organization": "gymcrush"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b975cb8-e751-482a-8b1b-75d316cd7613"
      }
    }
  }
}
