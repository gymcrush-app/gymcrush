EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
# Required for seed scripts against remote (staging/production). For local, anon key is used if this is unset.
SUPABASE_SERVICE_ROLE_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
EXPO_PUBLIC_MIXPANEL_TOKEN=

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=
ASC_APP_ID=
ASC_BUNDLE_ID=
ASC_IAP_KEY_ID=
ASC_IAP_KEY_PATH=
# ASC_VENDOR_NUMBER — from ASC → Payments and Financial Reports (top of page, ~8 digits).
# Required by RC for sales/financial reporting. Currently collected to .env but
# applied manually in RC dashboard until their v2 API exposes it.
ASC_VENDOR_NUMBER=

# RevenueCat (rc-setup skill, Phase 2+)
# RC_API_KEY_V2 — generated in RC Dashboard → profile → API keys (project-write scope).
# RC_PROJECT_ID — visible in the RC dashboard URL.
# RC_IOS_PUBLIC_KEY / EXPO_PUBLIC_RC_IOS_KEY — populated by the skill (public, safe in app bundle).
# RC_WEBHOOK_AUTH — generated by the skill (shared secret for Supabase edge fn auth).
RC_API_KEY_V2=
RC_PROJECT_ID=
RC_IOS_PUBLIC_KEY=
RC_WEBHOOK_AUTH=
EXPO_PUBLIC_RC_IOS_KEY=